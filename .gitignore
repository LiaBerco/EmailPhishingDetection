# raw corpora (large; download from Kaggle into data/raw/kaggle_phishing/)
# NOTE: exclude the *contents*, not the directory itself — git does not descend
# into an excluded directory, so a "!" rule inside one would never take effect.
data/raw/*
# ...but DO keep the small, parsed modern snapshots (reproducibility)
!data/raw/nazario_recent/
data/raw/nazario_recent/*
!data/raw/nazario_recent/nazario_recent.csv
!data/raw/modern_ham/
data/raw/modern_ham/*
!data/raw/modern_ham/modern_ham.csv
# frozen working snapshot is regenerated by the notebook
data/emails_working.csv

# python
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
venv/

# model caches
*.pt
.cache/

# latex build artifacts (keep main.tex + main.pdf)
report/*.aux
report/*.log
report/*.blg
report/*.bbl
report/*.out
report/*.toc

# os
Thumbs.db
.DS_Store

# office temp / lock files
~$*
